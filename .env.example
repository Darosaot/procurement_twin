# Procurement Digital Twin — Environment Variables
# Copy to .env and fill in values before starting.
# All variables have sensible defaults for local development.

# ── Security ───────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys for the REST API.
# Leave empty to disable authentication (development only).
# Generate a key:  python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEYS=

# Required: Jupyter notebook access token.
# Generate:  openssl rand -hex 32
JUPYTER_TOKEN=

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the REST API.
# Defaults to localhost:8050 and localhost:8888 if not set.
CORS_ORIGINS=http://localhost:8050,http://localhost:8888

# ── Rate limiting ───────────────────────────────────────────────────────────
# slowapi-style limit string: "<count>/<period>"
# Periods: second, minute, hour, day
RATE_LIMIT=60/minute

# ── Request timeout ─────────────────────────────────────────────────────────
# Max seconds before the API returns HTTP 504.
# Increase if running /policy with n_records=2000.
API_TIMEOUT_SECONDS=120

# ── Simulation cache ────────────────────────────────────────────────────────
# Set CACHE_ENABLED=0 to disable the LRU cache entirely.
CACHE_ENABLED=1
CACHE_MAXSIZE=500
CACHE_TTL=3600

# ── Simulation history (audit log) ──────────────────────────────────────────
# SQLite database path. Use a volume-mounted path for persistence.
# Default :memory: means history is lost on restart.
HISTORY_DB_PATH=/app/data/history.db
HISTORY_MAX_ROWS=10000

# ── Concurrency ─────────────────────────────────────────────────────────────
# Number of threads dedicated to long-running /policy and /benchmark calls.
POLICY_WORKERS=2

# ── File paths ──────────────────────────────────────────────────────────────
# Override default relative paths for model and feature store files.
# MODEL_DIR=/app/models
# FEAT_DIR=/app/data/features
# DATA_DIR=/app/data

# ── Hugging Face Hub ─────────────────────────────────────────────────────────
# Used by start.py to download model artifacts at container startup.
# HF_HOME=/home/user/.cache/huggingface
# HF_REPO_ID=your-org/procurement-twin

# ── Jupyter (docker-compose only) ───────────────────────────────────────────
# Internal API base URL for notebooks running inside the Docker network.
TWIN_API_BASE=http://api:8000
